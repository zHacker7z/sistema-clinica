# Porta da API
PORT=0000

# MongoDB Atlas (string de conexão)
MONGODB_URI=mongodb+srv://USUARIO:SENHA@cluster0.xxxxx.mongodb.net/sistema-atendimento?retryWrites=true&w=majority

# Chave secreta para JWT (troque por uma senha forte)
JWT_SECRET=uma_chave_forte_aqui
JWT_EXPIRES_IN=7d

# CORS - inclua a origem do frontend (local e Vercel)
# Exemplo (separadas por vírgula):
# CORS_ORIGINS=http://localhost:5173,https://seu-frontend-vercel.vercel.app
CORS_ORIGINS=http://localhost:5173

